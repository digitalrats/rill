```bash
# Новые примеры
cargo run --example talking_synth     # Синтезатор, который слышит себя
cargo run --example modular_patch     # Модульный патч с динамической коммутацией
cargo run --example wild_servo        # Демонстрация микро-контроля
cargo run --example ui_as_sensor      # Интеграция с egui
```

